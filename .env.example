# ============================================================
# Rosy — Business OS Credential Reference
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is NEVER committed to git.
# ============================================================

# ------------------------------------------------------------
# Mailchimp
# Get your API key from: Mailchimp → Account → Extras → API Keys
# Create a key named "Cursor-Rosy" for easy revocation.
# Server prefix is the last part of your API key (e.g. "us14")
# ------------------------------------------------------------
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1

# ------------------------------------------------------------
# WordPress / WooCommerce
# Site URL — no trailing slash
# Use an Application Password, NOT your admin login:
#   WordPress Admin → Users → Profile → Application Passwords
#   Create one named "Cursor-Rosy"
# Consumer Key and Secret come from:
#   WooCommerce → Settings → Advanced → REST API
# ------------------------------------------------------------
WOO_URL=https://your-site.com
WOO_CONSUMER_KEY=ck_your_key_here
WOO_CONSUMER_SECRET=cs_your_secret_here

# ------------------------------------------------------------
# Google Drive (optional)
# Download credentials JSON from Google Cloud Console.
# Paste the entire JSON as a single-line string.
# ------------------------------------------------------------
GOOGLE_DRIVE_CREDENTIALS_JSON=paste_full_json_string_here

# ------------------------------------------------------------
# Future integrations — add new credentials here as needed
# ------------------------------------------------------------
# CANVA_API_KEY=
# FL_DOR_USERNAME=
# FL_DOR_PASSWORD=
